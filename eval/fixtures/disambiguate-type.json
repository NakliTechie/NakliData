        "samples": ["27AAPFU0939F1ZV", "29AAGCB7383J1Z4", "07AABCU9603R1ZP"],
        "candidates": [
          { "typeId": "gstin", "displayName": "GSTIN" },
          { "typeId": "pan", "displayName": "PAN" }
        ]
      },
      "expected": { "typeId": "gstin" },
      "recordedResponse": "gstin"
    },
