      "recordedResponse": "{\"id\":\"mac_address\",\"display_name\":\"MAC Address\",\"category\":\"Identifier\",\"regex\":\"^([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}$\"}"
