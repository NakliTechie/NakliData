      "expected": { "category": "Code", "regexMatchesSamples": true, "idLike": "version" },
      "recordedResponse": "{\"id\":\"semver\",\"display_name\":\"Semantic Version\",\"category\":\"Code\",\"regex\":\"^[0-9]+\\\\.[0-9]+\\\\.[0-9]+$\"}"
