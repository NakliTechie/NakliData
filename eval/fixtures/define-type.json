      "expected": { "category": "Identifier", "regexMatchesSamples": true, "idLike": "order" },
      "recordedResponse": "{\"id\":\"order_no\",\"display_name\":\"Order Number\",\"category\":\"Identifier\",\"regex\":\"^ORD-[0-9]{4}-[0-9]{4}$\"}"
    },
