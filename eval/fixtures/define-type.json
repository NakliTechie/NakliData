{
  "job": "define-type",
  "_note": "Held-out cases for the define-new-type job. `recordedResponse` is a representative raw JSON model output used by --dry-run. Scoring checks category match + that the suggested regex compiles AND matches every sample. Grow toward 20-50 cases.",
  "cases": [
    {
      "id": "employee-id",
      "input": {
        "columnName": "emp_id",
        "sqlType": "VARCHAR",
        "samples": ["E0001", "E0042", "E1337"]
      },
      "expected": { "category": "Identifier", "regexMatchesSamples": true, "idLike": "employee" },
      "recordedResponse": "{\"id\":\"employee_id\",\"display_name\":\"Employee ID\",\"category\":\"Identifier\",\"regex\":\"^E[0-9]{4}$\"}"
    },
    {
      "id": "isbn-13",
      "input": {
        "columnName": "isbn",
        "sqlType": "VARCHAR",
        "samples": ["9780131103627", "9781491950296", "9780596007126"]
      },
      "expected": { "category": "Code", "regexMatchesSamples": true, "idLike": "isbn" },
      "recordedResponse": "{\"id\":\"isbn_13\",\"display_name\":\"ISBN-13\",\"category\":\"Code\",\"regex\":\"^97[89][0-9]{10}$\"}"
    },
    {
      "id": "order-number",
