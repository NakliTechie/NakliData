{
  "name": "naklidata",
  "version": "0.1.0",
  "description": "Browser-native semantic data workbench.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --dev",
    "check": "tsc --noEmit && biome check src tests eval && node scripts/check-engine-boundary.mjs && node scripts/check-bundle-size.mjs",
    "fmt": "biome format --write src tests eval",
    "lint": "biome lint src tests eval",
    "test": "vitest run",
    "test:e2e": "npm run build && npx playwright test --config tests/e2e/playwright.config.ts",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "eval": "node eval/run.mjs",
    "gen-examples": "node scripts/gen-examples.mjs",
    "test:watch": "vitest",
    "postinstall": "node scripts/fetch-duckdb-fallback.mjs && node scripts/fetch-duckdb-extensions.mjs"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.7.0",
    "@codemirror/lang-sql": "^6.8.0",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.34.0",
    "@deck.gl/core": "^9.3.2",
    "@deck.gl/layers": "^9.3.2",
    "@deck.gl/mapbox": "^9.3.2",
    "@duckdb/duckdb-wasm": "1.29.0",
    "@huggingface/transformers": "^4.2.0",
    "@observablehq/plot": "^0.6.17",
    "cytoscape": "^3.33.3",
    "maplibre-gl": "^5.24.0",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@playwright/test": "^1.60.0",
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^22.5.0",
    "esbuild": "^0.24.0",
    "playwright": "^1.60.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
